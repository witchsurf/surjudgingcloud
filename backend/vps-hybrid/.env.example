# Configuration du Serveur Hybride Surf Judging
PORT=4000

# URL de connexion directe à Supabase (PostgreSQL)
# Format: postgres://postgres.[USER]:[PASS]@[HOST]:5432/postgres
DATABASE_URL=postgres://your-db-url-here

# Clé de sécurité pour les tablettes juges et écrans
# Cette clé doit être configurée dans le frontend après la Ligue Pro
HYBRID_API_KEY=choose-a-strong-secret-key-here

# Debug (optionnel)
DEBUG=true
